# ─────────────────────────────────────────────────────────────────────────────
#  Sıra — .env.example. Copy to .env.local and fill in.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you. Every key is
#  OPTIONAL — with none set, Sıra runs in DEMO MODE with a sample waitlist.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend — sends confirmation, milestone & reward emails ───────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Supabase — stores signups, referrals & positions (optional) ──────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
